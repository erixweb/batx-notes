---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 ¡Bienvenido!</h1>

			<p>
				Aquí encontrarás apuntes para las materias de itenerario tecnológico para PAU 2027. También, ejercicios resueltos y con una explicación breve del resultado.
			</p>
		</main>
		<Footer />
	</body>
</html>
